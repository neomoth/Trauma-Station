<controls:FancyTree xmlns="https://spacestation14.io"
                    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls.FancyTree">
    <!-- <Trauma> - wrap in BoxContainer, add search for guidebook entries -->
    <BoxContainer Orientation="Vertical" MinWidth="200">
        <LineEdit Name="SearchBar" PlaceHolder="{Loc 'guidebook-filter-placeholder-text'}" HorizontalExpand="True" Margin="0 5 10 5"/>
        <ScrollContainer ReturnMeasure="True">
            <BoxContainer Orientation="Vertical" Name="Body" Access="Public" Margin="2"/>
        </ScrollContainer>
    </BoxContainer>
    <!-- </Trauma> -->
</controls:FancyTree>
